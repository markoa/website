---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort posts by date
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog">
  <main class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-8">Blog</h1>
    
    <div class="space-y-8">
      {sortedPosts.map((post) => (
        <article class="border-b border-gray-200 pb-8">
          {post.data.type === 'photo' && post.data.image && (
            <img 
              src={post.data.image} 
              alt={post.data.title}
              class="mb-4 rounded-lg max-h-96 object-cover w-full"
            />
          )}
          <div class="flex items-baseline gap-2 text-sm text-gray-600 mb-2">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <span class="px-2 py-1 bg-gray-100 rounded-full text-xs">
              {post.data.type}
            </span>
          </div>
          
          <h2 class="text-2xl font-semibold mb-2">
            {post.data.type === 'link' ? (
              <a href={post.data.url} class="hover:text-blue-600">
                {post.data.title} →
              </a>
            ) : (
              <a href={`/blog/${post.slug}`} class="hover:text-blue-600">
                {post.data.title}
              </a>
            )}
          </h2>
          
          {post.data.description && (
            <p class="text-gray-600">{post.data.description}</p>
          )}
        </article>
      ))}
    </div>
  </main>
</Layout>
